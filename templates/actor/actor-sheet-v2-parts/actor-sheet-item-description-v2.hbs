{{log "actor-sheet-item-description-v2" this}}

<div class="item-column item-description item-depth-{{this.childDepth}}"
    data-tooltip="{{this.validationTooltip}}"
>
    {{#if this.validationTooltip}}
        <i class="fa-regular fa-circle-exclamation fa-2xl"></i>
    {{else}}
        {{#if this.isContainer}}
            <a class="item-image item-chevron" data-action="toggleChevron">
                <i class="fas fa-square-caret-down fa-2x"></i>
            </a>
        {{else}}
            {{#if (ne this.system.XMLID "LIST")}}
                <img class="item-image" src="{{this.img}}" alt="{{this.name}}">
            {{/if}}
        {{/if}}
    {{/if}}

    <div class="item-description-full {{this.css.description}}">
        {{#if (and this.childIdx this.parentItem)}}
            {{this.childIdx}})
        {{/if}}
        {{{itemFullDescription this}}}
        {{#if this.system.NOTES}}
            <div class="item-notes-editable-content"><b>Notes:</b> {{{this.system.NOTES}}}</div>
        {{/if}}
    </div>
    
</div>